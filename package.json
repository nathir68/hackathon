{
    "name": "hire-ai-portal",
    "version": "1.0.0",
    "description": "Full Stack AI Job Portal",
    "scripts": {
        "start": "concurrently \"npm run server\" \"npm run client\"",
        "dev": "concurrently \"npm run server:dev\" \"npm run client\"",
        "server": "npm start --prefix backend",
        "server:dev": "npm run dev --prefix backend",
        "client": "npm start --prefix HIRE/frontend",
        "install": "npm install --prefix backend && npm install --prefix HIRE/frontend",
        "build": "npm run build --prefix HIRE/frontend"
    },
    "dependencies": {
        "concurrently": "^8.2.2",
        "pdf-lib": "^1.17.1"
    }
}
